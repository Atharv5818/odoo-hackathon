# .env.example
# Copy to .env and fill in real values. NEVER commit .env to git.

NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/traveloop_db

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters. Use different secrets for access and refresh.
JWT_ACCESS_SECRET=generate_a_random_64_char_hex_string_here
JWT_REFRESH_SECRET=generate_a_different_random_64_char_hex_string_here

# Token expiry — use ms-style notation: 15m, 7d, 1h
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin (for CORS)
CLIENT_ORIGIN=http://localhost:5173

# bcrypt cost factor — 12 is the production minimum. Don't go below 10.
BCRYPT_ROUNDS=12
